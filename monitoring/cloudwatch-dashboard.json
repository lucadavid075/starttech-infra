{
  "widgets": [
    {
      "type": "metric",
      "x": 0, "y": 0, "width": 12, "height": 6,
      "properties": {
        "title": "ALB — Request Count & Latency",
        "view": "timeSeries",
        "period": 60,
        "metrics": [
          ["AWS/ApplicationELB", "RequestCount", "LoadBalancer", "${alb_arn_suffix}", {"stat": "Sum", "label": "Requests/min", "yAxis": "left"}],
          ["AWS/ApplicationELB", "TargetResponseTime", "LoadBalancer", "${alb_arn_suffix}", {"stat": "p95", "label": "P95 Latency (s)", "yAxis": "right"}]
        ],
        "yAxis": { "left": {"label": "Count"}, "right": {"label": "Seconds"} }
      }
    },
    {
      "type": "metric",
      "x": 12, "y": 0, "width": 12, "height": 6,
      "properties": {
        "title": "ALB — HTTP Error Rates",
        "view": "timeSeries",
        "period": 60,
        "metrics": [
          ["AWS/ApplicationELB", "HTTPCode_ELB_4XX_Count", "LoadBalancer", "${alb_arn_suffix}", {"stat": "Sum", "label": "4xx", "color": "#ff9900"}],
          ["AWS/ApplicationELB", "HTTPCode_ELB_5XX_Count", "LoadBalancer", "${alb_arn_suffix}", {"stat": "Sum", "label": "5xx", "color": "#d62728"}]
        ]
      }
    },
    {
      "type": "metric",
      "x": 0, "y": 6, "width": 8, "height": 6,
      "properties": {
        "title": "ASG — Instance Count",
        "view": "timeSeries",
        "period": 60,
        "metrics": [
          ["AWS/AutoScaling", "GroupInServiceInstances", "AutoScalingGroupName", "${asg_name}", {"stat": "Average", "label": "In Service"}],
          ["AWS/AutoScaling", "GroupTotalInstances", "AutoScalingGroupName", "${asg_name}", {"stat": "Average", "label": "Total"}]
        ]
      }
    },
    {
      "type": "metric",
      "x": 8, "y": 6, "width": 8, "height": 6,
      "properties": {
        "title": "EC2 — CPU & Memory",
        "view": "timeSeries",
        "period": 60,
        "metrics": [
          ["AWS/EC2", "CPUUtilization", "AutoScalingGroupName", "${asg_name}", {"stat": "Average", "label": "CPU %"}],
          ["StartTech/prod", "mem_used_percent", "AutoScalingGroupName", "${asg_name}", {"stat": "Average", "label": "Memory %"}]
        ]
      }
    },
    {
      "type": "metric",
      "x": 16, "y": 6, "width": 8, "height": 6,
      "properties": {
        "title": "ElastiCache Redis — Connections & Hits",
        "view": "timeSeries",
        "period": 60,
        "metrics": [
          ["AWS/ElastiCache", "CurrConnections", "CacheClusterId", "starttech-prod-redis", {"stat": "Average", "label": "Connections"}],
          ["AWS/ElastiCache", "CacheHits", "CacheClusterId", "starttech-prod-redis", {"stat": "Sum", "label": "Cache Hits"}],
          ["AWS/ElastiCache", "CacheMisses", "CacheClusterId", "starttech-prod-redis", {"stat": "Sum", "label": "Cache Misses"}]
        ]
      }
    },
    {
      "type": "log",
      "x": 0, "y": 12, "width": 24, "height": 8,
      "properties": {
        "title": "Backend — Recent Error Logs",
        "query": "SOURCE '/starttech/prod/backend' | fields @timestamp, @message | filter @message like /(?i)(error|panic|fatal)/ | sort @timestamp desc | limit 100",
        "region": "us-east-1",
        "view": "table"
      }
    }
  ]
}
